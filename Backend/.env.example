# Configuración del Servidor
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8100,http://localhost:4200

# Base de Datos (PostgreSQL)
DB_USER=postgres
DB_HOST=localhost
NOMBRE_DB=asistec_db
MI_CLAVE_POSTGRES=tu_contraseña_aqui
DB_PORT=5432

# Seguridad (JWT)
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_clave_secreta_super_segura_aqui

# AWS S3 (Almacenamiento de Imágenes)
# Obtén estas credenciales en la consola de AWS IAM
AWS_REGION=us-east-1
AWS_BUCKET_NAME=nombre-de-tu-bucket
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=clave_secreta...
